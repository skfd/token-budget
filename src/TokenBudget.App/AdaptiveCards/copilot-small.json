{
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.5",
    "body": [
        {
            "type": "TextBlock",
            "text": "Copilot monthly quota",
            "weight": "bolder",
            "size": "default"
        },
        {
            "type": "ColumnSet",
            "spacing": "small",
            "columns": [
                {
                    "type": "Column",
                    "width": "stretch",
                    "items": [
                        {
                            "type": "ColumnSet",
                            "$when": "${barStyle == 'accent'}",
                            "spacing": "none",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "${percentValueClamped}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "accent"
                                },
                                {
                                    "type": "Column",
                                    "width": "${percentRemaining}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "emphasis"
                                }
                            ]
                        },
                        {
                            "type": "ColumnSet",
                            "$when": "${barStyle == 'warning'}",
                            "spacing": "none",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "${percentValueClamped}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "warning"
                                },
                                {
                                    "type": "Column",
                                    "width": "${percentRemaining}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "emphasis"
                                }
                            ]
                        },
                        {
                            "type": "ColumnSet",
                            "$when": "${barStyle == 'attention'}",
                            "spacing": "none",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "${percentValueClamped}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "attention"
                                },
                                {
                                    "type": "Column",
                                    "width": "${percentRemaining}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "emphasis"
                                }
                            ]
                        }
                    ]
                },
                {
                    "type": "Column",
                    "width": "auto",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "${percentText} used",
                            "size": "small",
                            "weight": "lighter",
                            "color": "${statusColor}"
                        }
                    ],
                    "verticalContentAlignment": "center"
                }
            ]
        },
        {
            "type": "TextBlock",
            "text": "${resetTime}",
            "size": "small",
            "weight": "lighter",
            "isSubtle": true,
            "spacing": "none"
        }
    ],
    "backgroundImage": {
        "url": "data:image/png;base64,",
        "fillMode": "repeatVertically"
    }
}
