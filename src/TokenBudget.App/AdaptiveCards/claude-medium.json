{
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.5",
    "body": [
        {
            "type": "TextBlock",
            "text": "Plan usage limits",
            "weight": "bolder",
            "size": "medium"
        },
        {
            "type": "TextBlock",
            "text": "Current session",
            "weight": "bolder",
            "size": "default",
            "spacing": "small"
        },
        {
            "type": "TextBlock",
            "text": "${resetTime}",
            "size": "small",
            "weight": "lighter",
            "isSubtle": true,
            "spacing": "none"
        },
        {
            "type": "ColumnSet",
            "spacing": "small",
            "columns": [
                {
                    "type": "Column",
                    "width": "stretch",
                    "items": [
                        {
                            "type": "ColumnSet",
                            "$when": "${barStyle == 'accent'}",
                            "spacing": "none",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "${percentValueClamped}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "accent"
                                },
                                {
                                    "type": "Column",
                                    "width": "${percentRemaining}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "emphasis"
                                }
                            ]
                        },
                        {
                            "type": "ColumnSet",
                            "$when": "${barStyle == 'warning'}",
                            "spacing": "none",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "${percentValueClamped}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "warning"
                                },
                                {
                                    "type": "Column",
                                    "width": "${percentRemaining}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "emphasis"
                                }
                            ]
                        },
                        {
                            "type": "ColumnSet",
                            "$when": "${barStyle == 'attention'}",
                            "spacing": "none",
                            "columns": [
                                {
                                    "type": "Column",
                                    "width": "${percentValueClamped}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "attention"
                                },
                                {
                                    "type": "Column",
                                    "width": "${percentRemaining}",
                                    "items": [],
                                    "minHeight": "4px",
                                    "style": "emphasis"
                                }
                            ]
                        }
                    ],
                    "verticalContentAlignment": "center"
                },
                {
                    "type": "Column",
                    "width": "auto",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "${percentText} used",
                            "size": "small",
                            "weight": "lighter",
                            "color": "${statusColor}"
                        }
                    ],
                    "verticalContentAlignment": "center"
                }
            ]
        },
        {
            "type": "TextBlock",
            "text": "${extraUsage}",
            "size": "small",
            "isSubtle": true,
            "spacing": "none",
            "$when": "${extraUsage != ''}"
        },
        {
            "type": "Container",
            "spacing": "default",
            "separator": true,
            "items": [
                {
                    "type": "TextBlock",
                    "text": "Weekly limits",
                    "weight": "bolder",
                    "size": "default",
                    "spacing": "small"
                },
                {
                    "type": "TextBlock",
                    "text": "All models",
                    "size": "small",
                    "weight": "lighter",
                    "isSubtle": true,
                    "spacing": "none"
                },
                {
                    "type": "TextBlock",
                    "text": "${sevenDayReset}",
                    "size": "small",
                    "weight": "lighter",
                    "isSubtle": true,
                    "spacing": "none"
                },
                {
                    "type": "ColumnSet",
                    "spacing": "small",
                    "columns": [
                        {
                            "type": "Column",
                            "width": "stretch",
                            "items": [
                                {
                                    "type": "ColumnSet",
                                    "$when": "${sevenDayBarStyle == 'accent'}",
                                    "spacing": "none",
                                    "columns": [
                                        {
                                            "type": "Column",
                                            "width": "${sevenDayValueClamped}",
                                            "items": [],
                                            "minHeight": "4px",
                                            "style": "accent"
                                        },
                                        {
                                            "type": "Column",
                                            "width": "${sevenDayRemaining}",
                                            "items": [],
                                            "minHeight": "4px",
                                            "style": "emphasis"
                                        }
                                    ]
                                },
                                {
                                    "type": "ColumnSet",
                                    "$when": "${sevenDayBarStyle == 'warning'}",
                                    "spacing": "none",
                                    "columns": [
                                        {
                                            "type": "Column",
                                            "width": "${sevenDayValueClamped}",
                                            "items": [],
                                            "minHeight": "4px",
                                            "style": "warning"
                                        },
                                        {
                                            "type": "Column",
                                            "width": "${sevenDayRemaining}",
                                            "items": [],
                                            "minHeight": "4px",
                                            "style": "emphasis"
                                        }
                                    ]
                                },
                                {
                                    "type": "ColumnSet",
                                    "$when": "${sevenDayBarStyle == 'attention'}",
                                    "spacing": "none",
                                    "columns": [
                                        {
                                            "type": "Column",
                                            "width": "${sevenDayValueClamped}",
                                            "items": [],
                                            "minHeight": "4px",
                                            "style": "attention"
                                        },
                                        {
                                            "type": "Column",
                                            "width": "${sevenDayRemaining}",
                                            "items": [],
                                            "minHeight": "4px",
                                            "style": "emphasis"
                                        }
                                    ]
                                }
                            ],
                            "verticalContentAlignment": "center"
                        },
                        {
                            "type": "Column",
                            "width": "auto",
                            "items": [
                                {
                                    "type": "TextBlock",
                                    "text": "${sevenDayPercent} used",
                                    "size": "small",
                                    "weight": "lighter",
                                    "color": "${sevenDayStatusColor}"
                                }
                            ],
                            "verticalContentAlignment": "center"
                        }
                    ]
                }
            ]
        }
    ],
    "backgroundImage": {
        "url": "data:image/png;base64,",
        "fillMode": "repeatVertically"
    }
}
