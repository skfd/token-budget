{
    "type": "AdaptiveCard",
    "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
    "version": "1.6",
    "body": [
        {
            "type": "TextBlock",
            "text": "Plan usage limits",
            "weight": "bolder",
            "size": "default"
        },
        {
            "type": "ColumnSet",
            "spacing": "small",
            "columns": [
                {
                    "type": "Column",
                    "width": "stretch",
                    "items": [
                        {
                            "type": "ProgressBar",
                            "value": "${percentValue}",
                            "max": 100,
                            "color": "${barColor}"
                        }
                    ],
                    "verticalContentAlignment": "center"
                },
                {
                    "type": "Column",
                    "width": "auto",
                    "items": [
                        {
                            "type": "TextBlock",
                            "text": "${percentText} used",
                            "size": "small",
                            "weight": "lighter",
                            "color": "${statusColor}"
                        }
                    ],
                    "verticalContentAlignment": "center"
                }
            ]
        },
        {
            "type": "TextBlock",
            "text": "${resetTime}",
            "size": "small",
            "weight": "lighter",
            "isSubtle": true,
            "spacing": "none"
        }
    ],
    "backgroundImage": {
        "url": "data:image/png;base64,",
        "fillMode": "repeatVertically"
    }
}
